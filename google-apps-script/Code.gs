function getSpreadsheet_() {
  return SpreadsheetApp.openById(getSpreadsheetId_());
}

function getSheet_() {
  var ss = getSpreadsheet_();
  var sheetName = getSheetName_();
  var sheetGid = getSheetGid_();
  var sheet = ss.getSheetByName(sheetName);
  if (!sheet && sheetGid) {
    var sheets = ss.getSheets();
    for (var i = 0; i < sheets.length; i++) {
      if (sheets[i].getSheetId() === sheetGid) {
        sheet = sheets[i];
        break;
      }
    }
  }
  if (!sheet) throw new Error('לא נמצא גיליון "' + sheetName + '"');
  return sheet;
}

function getDataStartRow_(sheet) {
  var first = sheet.getRange(1, 1, 1, NUM_COLS).getValues()[0];
  var a = String(first[0]).trim().toLowerCase();
  var b = String(first[1]).trim().toLowerCase();
  if (a === 'id' || a === 'מזהה' || b === 'firstname' || b === 'שם פרטי') return 2;
  return 1;
}

function normalizeNamePart_(s) {
  return String(s || '')
    .trim()
    .replace(/\s+/g, ' ');
}

function normalizePhone_(phone) {
  var raw = String(phone || '').trim();
  if (/^(?:\+972-\d{1,2}-\d{7}|0\d{1,2}-\d{7})$/.test(raw)) return raw;
  var digits = raw.replace(/\D/g, '');
  if (raw.indexOf('+972') === 0 || (digits.indexOf('972') === 0 && digits.length >= 11)) {
    var local = digits.indexOf('972') === 0 ? digits.slice(3) : digits;
    if (local.length === 9) return '+972-' + local.charAt(0) + '-' + local.slice(1);
    if (local.length === 10 && local.charAt(0) === '0') {
      return '+972-' + local.charAt(1) + '-' + local.slice(2);
    }
  }
  if (digits.length === 10 && digits.charAt(0) === '0') {
    return digits.slice(0, 3) + '-' + digits.slice(3);
  }
  if (digits.length === 9) return '0' + digits.charAt(0) + '-' + digits.slice(1);
  return raw;
}

function isValidPhone_(phone) {
  return /^(?:\+972-\d{1,2}-\d{7}|0\d{1,2}-\d{7})$/.test(String(phone || '').trim());
}

function normalizeContact_(c) {
  return {
    id: String(c && c.id != null && c.id !== '' ? c.id : Utilities.getUuid()),
    firstName: normalizeNamePart_(c && c.firstName),
    lastName: normalizeNamePart_(c && c.lastName),
    phone: normalizePhone_(c && c.phone),
    email: String((c && c.email) || '')
      .trim()
      .toLowerCase(),
  };
}

function rowToContact_(row) {
  return normalizeContact_({
    id: row[0],
    firstName: row[1],
    lastName: row[2],
    phone: row[3],
    email: row[4],
  });
}

function phoneDigits_(phone) {
  var d = String(phone || '').replace(/\D/g, '');
  if (d.length === 12 && d.indexOf('972') === 0) d = '0' + d.slice(3);
  if (d.length === 9 && d.charAt(0) !== '0') d = '0' + d;
  return d;
}

function contactDedupeKey_(c) {
  var digits = phoneDigits_(c.phone);
  if (digits.length >= 9) return 'p:' + digits;
  var name = (normalizeNamePart_(c.firstName) + ' ' + normalizeNamePart_(c.lastName))
    .trim()
    .toLowerCase();
  if (name) return 'n:' + name;
  return 'id:' + String(c.id || '');
}

function contactScore_(c) {
  var s = 0;
  if (c.firstName) s += 2;
  if (c.lastName) s += 2;
  if (isValidPhone_(c.phone)) s += 5;
  if (c.email) s += 1;
  return s;
}

function dedupeContactsFromMap_(map) {
  return Object.keys(map).map(function (k) {
    return map[k];
  });
}

function sortContacts_(list) {
  return list.sort(function (a, b) {
    var na = (normalizeNamePart_(a.firstName) + ' ' + normalizeNamePart_(a.lastName)).trim();
    var nb = (normalizeNamePart_(b.firstName) + ' ' + normalizeNamePart_(b.lastName)).trim();
    try {
      return na.localeCompare(nb, 'he');
    } catch (e) {
      return na < nb ? -1 : na > nb ? 1 : 0;
    }
  });
}

function getContacts_() {
  var sheet = getSheet_();
  var lastRow = sheet.getLastRow();
  if (lastRow < 1) return [];

  var startRow = getDataStartRow_(sheet);
  var rows = sheet.getRange(startRow, 1, lastRow, NUM_COLS).getValues();

  var map = rows.reduce(function (acc, row) {
    var c = rowToContact_(row);
    if (!c.firstName && !c.lastName && !c.phone) return acc;
    var key = contactDedupeKey_(c);
    if (!acc[key] || contactScore_(c) > contactScore_(acc[key])) acc[key] = c;
    return acc;
  }, {});

  return sortContacts_(dedupeContactsFromMap_(map));
}

function getNextId_(sheet) {
  var lastRow = sheet.getLastRow();
  var startRow = getDataStartRow_(sheet);
  var nextId = 1;
  if (lastRow >= startRow) {
    var ids = sheet.getRange(startRow, 1, lastRow, 1).getValues();
    ids.forEach(function (r) {
      var n = parseInt(r[0], 10);
      if (!isNaN(n) && n >= nextId) nextId = n + 1;
    });
  }
  return nextId;
}

function isDuplicatePhone_(phone, excludeId) {
  var digits = phoneDigits_(phone);
  if (digits.length < 9) return false;
  var sheet = getSheet_();
  var lastRow = sheet.getLastRow();
  if (lastRow < 1) return false;
  var startRow = getDataStartRow_(sheet);
  var rows = sheet.getRange(startRow, 1, lastRow, NUM_COLS).getValues();
  for (var i = 0; i < rows.length; i++) {
    var c = rowToContact_(rows[i]);
    if (excludeId && String(c.id) === String(excludeId)) continue;
    if (phoneDigits_(c.phone) === digits) return true;
  }
  return false;
}

function appendContact_(c) {
  var normalized = normalizeContact_(c || {});
  var phone = normalized.phone;
  if (!isValidPhone_(phone)) {
    return { ok: false, error: 'טלפון לא תקין (058-1234567 או 02-1234567 או +972-5X-XXXXXXX)' };
  }
  if (isDuplicatePhone_(phone)) {
    return { ok: false, error: 'איש קשר עם מספר זה כבר קיים' };
  }

  var sheet = getSheet_();
  var id = getNextId_(sheet);
  sheet.appendRow([id, normalized.firstName, normalized.lastName, phone, normalized.email]);

  return {
    ok: true,
    contact: {
      id: String(id),
      firstName: normalized.firstName,
      lastName: normalized.lastName,
      phone: phone,
      email: normalized.email,
    },
  };
}

function authCache_() {
  return CacheService.getScriptCache();
}

function checkAuth_(token) {
  if (!token) return false;
  return authCache_().get('auth_' + token) === '1';
}

function verifyPasswordPublic(password) {
  if (String(password) !== getAddPassword_()) {
    return { ok: false, error: 'סיסמה שגויה' };
  }
  var token = Utilities.getUuid();
  authCache_().put('auth_' + token, '1', getAuthCacheHours_() * 3600);
  return { ok: true, token: token };
}

/**
 * מחזיר מקור לוגו לכותרת: כתובת URL אם LOGO_URL הוגדר, אחרת base64 גולמי.
 * (נטען בדפדפן דרך google.script.run)
 */
/** ללקוח: אובייקט לוגו (base64 מחולק או dataUri) */
function getBrandLogoBootstrapPublic() {
  return JSON.parse(getBrandLogoBootstrapJson_());
}

/** ללקוח: data URI מלא (גיבוי ישן) */
function getBrandLogoBase64Public() {
  return getBrandLogoImgSrc_();
}

/** גיבוי אחרון ל-onerror בדפדפן */
function getFallbackLogoDataUriPublic() {
  return getFallbackIconDataUri_(180);
}

function listContactsPublic() {
  return { ok: true, contacts: getContacts_() };
}

function dedupeSheetPublic(token) {
  if (!checkAuth_(token)) {
    return { ok: false, error: 'הזן סיסמה תחילה (ניהול)' };
  }

  var lock = LockService.getScriptLock();
  var acquired = false;
  try {
    acquired = lock.tryLock(LOCK_TIMEOUT_MS);
    if (!acquired) {
      return { ok: false, error: 'הגיליון בשימוש – נסה שוב בעוד רגע' };
    }

    var sheet = getSheet_();
    var startRow = getDataStartRow_(sheet);
    var lastRow = sheet.getLastRow();
    if (lastRow < startRow) {
      return { ok: true, removed: 0, total: 0 };
    }

    var rows = sheet.getRange(startRow, 1, lastRow, NUM_COLS).getValues();
    var before = rows.length;
    var map = rows.reduce(function (acc, row) {
      var c = rowToContact_(row);
      if (!c.firstName && !c.lastName && !c.phone) return acc;
      var key = contactDedupeKey_(c);
      if (!acc[key] || contactScore_(c) > contactScore_(acc[key])) acc[key] = c;
      return acc;
    }, {});
    var unique = sortContacts_(dedupeContactsFromMap_(map));
    var removed = before - unique.length;

    sheet.getRange(startRow, 1, lastRow, NUM_COLS).clearContent();
    if (unique.length) {
      var data = unique.map(function (c) {
        return [c.id, c.firstName, c.lastName, c.phone, c.email];
      });
      sheet.getRange(startRow, 1, startRow + unique.length - 1, NUM_COLS).setValues(data);
    }

    return { ok: true, removed: removed, total: unique.length };
  } catch (err) {
    return { ok: false, error: String(err) };
  } finally {
    if (acquired) lock.releaseLock();
  }
}

function addContactPublic(token, contact) {
  if (!checkAuth_(token)) {
    return { ok: false, error: 'הזן סיסמה תחילה (ניהול)' };
  }
  return appendContact_(contact || {});
}

function importContactsPublic(token, contacts) {
  if (!checkAuth_(token)) {
    return { ok: false, error: 'הזן סיסמה תחילה (ניהול)' };
  }
  if (!contacts || !contacts.length) {
    return { ok: false, error: 'אין אנשי קשר לייבוא' };
  }

  var added = [];
  var skipped = [];
  var existingPhones = {};
  getContacts_().forEach(function (c) {
    var d = phoneDigits_(c.phone);
    if (d) existingPhones[d] = true;
  });

  contacts.forEach(function (c) {
    var normalized = normalizeContact_(c);
    var d = phoneDigits_(normalized.phone);
    if (d && existingPhones[d]) {
      skipped.push(normalized.phone);
      return;
    }
    var res = appendContact_(normalized);
    if (res.ok) {
      added.push(res.contact);
      if (d) existingPhones[d] = true;
    } else {
      skipped.push(res.error);
    }
  });

  return {
    ok: true,
    addedCount: added.length,
    skippedCount: skipped.length,
    contacts: added,
  };
}

function jsonResponse_(payload) {
  return ContentService.createTextOutput(JSON.stringify(payload)).setMimeType(
    ContentService.MimeType.JSON
  );
}

// --- PWA icon PNG (base64), generated by scripts/generate-pwa-icons.mjs ---
var ICON_B64_180 = '';
var ICON_B64_192 = '';
var ICON_B64_512 = '';
// --- end PWA icons ---

function getIconPngBase64_(size) {
  var s = Number(size) || 192;
  if (s <= 180) return ICON_B64_180;
  if (s <= 192) return ICON_B64_192;
  return ICON_B64_512;
}

/** מחזיר כתובת לוגו מותאם או data URI מוטמע (לשימוש ב-href/src בתבנית HTML) */
/** גרסת אייקון PWA – העלה אחרי שינוי לוגו + Deploy New version */
var PWA_ICON_VERSION = 31;

/** כתובת אייקון PNG דרך האפליקציה (מסך הבית / manifest) */
function getIconServeUrl_(size) {
  var s = Number(size) || 180;
  var base = getWebAppUrlForClients_();
  if (!base) return '';
  return base + '?action=icon&size=' + s + '&v=' + PWA_ICON_VERSION;
}

/** לשימוש ב-href/src בתבנית HTML – מעדיף כתובת icon (קטן ויציב יותר מ-data URI) */
function getIconDataUri_(size) {
  return getIconHref_(size);
}

/** CSS מוטמע בדף – הלוגו נטען בשרת (עובד בתוך מסגרת Apps Script) */
function getBrandLogoCssBlock_() {
  return (
    '#brand-logo{background-image:url(' +
    JSON.stringify(getIconDataUri_(180)) +
    ');background-size:cover;background-position:center;background-repeat:no-repeat;}'
  );
}

/** כתובת PNG ללוגו בכותרת (?action=icon) */
function getBrandLogoIconUrl_() {
  return getIconServeUrl_(180);
}

/** מזהה קובץ אייקון PWA ב-Drive (נוצר אוטומטית בפעם הראשונה) */
function getPwaIconDriveFileId_() {
  return getProp_('PWA_ICON_FILE_ID', '');
}

function getDriveIconThumbUrl_(fileId, size) {
  var sz = Number(size) || 192;
  return 'https://drive.google.com/thumbnail?id=' + fileId + '&sz=w' + sz;
}

/** קישור ישיר ל-PNG – גיבוי */
function getDriveIconDirectUrl_(fileId) {
  return 'https://drive.google.com/uc?export=view&id=' + fileId;
}

/** CDN של Google – מועדף לאייקון מסך הבית ב-Android */
function getDriveIconLh3Url_(fileId, size) {
  var s = Number(size) || 192;
  return 'https://lh3.googleusercontent.com/d/' + fileId + '=w' + s + '-h' + s;
}

function ensurePwaIconPublicSharing_(fileId) {
  DriveApp.getFileById(fileId).setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
}

function storePwaIconUrls_(fileId) {
  var lh3 = getDriveIconLh3Url_(fileId, 192);
  var favicon = getDriveFaviconUrlForGas_(fileId);
  var props = PropertiesService.getScriptProperties();
  props.setProperty('PWA_ICON_FILE_ID', fileId);
  props.setProperty('PWA_ICON_PUBLIC_URL', lh3);
  props.setProperty('PWA_ICON_URL', favicon);
}

/** יוצר PNG ב-Drive עם שיתוף ציבורי – Chrome לא משתמש באייקון מ-script.google.com */
function getOrCreatePwaIconOnDrive_() {
  var props = PropertiesService.getScriptProperties();
  var fileId = props.getProperty('PWA_ICON_FILE_ID');
  if (fileId) {
    try {
      DriveApp.getFileById(fileId);
      return fileId;
    } catch (e) {
      props.deleteProperty('PWA_ICON_FILE_ID');
      props.deleteProperty('PWA_ICON_PUBLIC_URL');
    }
  }
  var lock = LockService.getScriptLock();
  lock.waitLock(15000);
  try {
    fileId = props.getProperty('PWA_ICON_FILE_ID');
    if (fileId) return fileId;
    var blob = Utilities.newBlob(
      Utilities.base64Decode(getIconPngBase64_(512)),
      'image/png',
      'contacts-yelm-pwa-icon.png'
    );
    var file = DriveApp.createFile(blob);
    fileId = file.getId();
    ensurePwaIconPublicSharing_(fileId);
    storePwaIconUrls_(fileId);
    return fileId;
  } finally {
    lock.releaseLock();
  }
}

/**
 * כתובת HTTPS לאייקון מסך הבית (חייבת להיות מחוץ ל-script.google.com).
 * Chrome מציג G אם האייקון רק מ-Apps Script או רק מ-JavaScript.
 */
function getPublicPwaIconUrl_(size) {
  var custom = String(getProp_('PWA_ICON_URL', '') || '').trim();
  if (custom && /^https?:\/\//i.test(custom) && !/script\.google\.com/i.test(custom)) {
    return custom;
  }
  var fileId = getPwaIconDriveFileId_();
  if (fileId) {
    try {
      return getDriveIconLh3Url_(fileId, size);
    } catch (e) {
      Logger.log('getPublicPwaIconUrl_ Drive: ' + e);
    }
  }
  return getIconServeUrl_(size);
}

/**
 * כתובת ל-setFaviconUrl() – חייבת להסתיים ב-png (GAS בודק סיומת).
 * @see https://stackoverflow.com/a/67123445 (export=download&format=png)
 */
function getDriveFaviconUrlForGas_(fileId) {
  return 'https://drive.google.com/uc?id=' + fileId + '&export=download&format=png';
}

function normalizeFaviconUrlForGas_(url) {
  url = String(url || '').trim().replace(/#.*$/, '');
  if (!url || /script\.google\.com/i.test(url)) return '';
  if (/format=png/i.test(url)) return url;
  var fileId = extractDriveFileId_(url);
  if (fileId) return getDriveFaviconUrlForGas_(fileId);
  if (/\.png(\?|$)/i.test(url)) return url;
  return '';
}

/**
 * כתובת ל-setFaviconUrl() ב-doGet – אייקון "הוסף למסך הבית" באנדרואיד.
 * תגיות <link rel="icon"> ב-HTML מתעלמות ב-Apps Script.
 */
function getFaviconUrlForWebApp_() {
  var custom = String(getProp_('PWA_ICON_URL', '') || '').trim();
  if (custom) {
    var normalized = normalizeFaviconUrlForGas_(custom);
    if (normalized) return normalized;
  }
  var fileId = getPwaIconDriveFileId_();
  if (fileId) return getDriveFaviconUrlForGas_(fileId);
  return '';
}

/** setFaviconUrl עלול לזרוק – לא שוברים את כל האתר */
function applyWebAppFavicon_(htmlOutput) {
  var url = getFaviconUrlForWebApp_();
  if (!url) return htmlOutput;
  try {
    return htmlOutput.setFaviconUrl(url);
  } catch (e) {
    Logger.log('setFaviconUrl נכשל (' + url + '): ' + e);
    return htmlOutput;
  }
}

/** עדכן קישורי אייקון (אחרי setupPwaIconOnDrive) – uc?export=view לטלפון */
function refreshPwaIconUrls() {
  var fileId = getPwaIconDriveFileId_();
  if (!fileId) {
    Logger.log('אין PWA_ICON_FILE_ID – הרץ setupPwaIconOnDrive קודם');
    return;
  }
  ensurePwaIconPublicSharing_(fileId);
  storePwaIconUrls_(fileId);
  Logger.log('setFaviconUrl (מסך הבית): ' + getFaviconUrlForWebApp_());
  Logger.log('manifest icons (lh3): ' + getDriveIconLh3Url_(fileId, 192));
  Logger.log('גיבוי uc: ' + getDriveIconDirectUrl_(fileId));
}

/** הרץ פעם מהעורך – יוצר/מחדש אייקון PWA ב-Drive (אחרי שינוי לוגו) */
function setupPwaIconOnDrive() {
  var props = PropertiesService.getScriptProperties();
  props.deleteProperty('PWA_ICON_FILE_ID');
  props.deleteProperty('PWA_ICON_PUBLIC_URL');
  var id = getOrCreatePwaIconOnDrive_();
  Logger.log('אייקון PWA ב-Drive: ' + id);
  Logger.log('כתובת לאייקון מסך הבית: ' + getPublicPwaIconUrl_(192));
  Logger.log('setFaviconUrl: ' + getFaviconUrlForWebApp_());
  Logger.log('פתח בדפדפן – אמורה להופיע תמונת הלוגו מלאה (ללא שוליים אפורים)');
  Logger.log('אחרי שינוי אייקון: Deploy → New version, מחק קיצור ישן, הוסף למסך הבית');
}

/**
 * אם createFile נחסם – העלה ידנית PNG ל-Drive, שתף "כל מי שיש לו את הקישור",
 * והרץ: registerPwaIconDriveFile('מזהה-או-קישור-Drive')
 */
function registerPwaIconDriveFile(fileIdOrUrl) {
  var fileId = extractDriveFileId_(fileIdOrUrl) || String(fileIdOrUrl || '').trim();
  if (!fileId) {
    Logger.log('חסר מזהה קובץ. העלה PNG ל-Drive, שתף לצפייה, והדבק מזהה או קישור.');
    return;
  }
  try {
    DriveApp.getFileById(fileId);
  } catch (e) {
    Logger.log('לא נמצא קובץ: ' + e);
    return;
  }
  ensurePwaIconPublicSharing_(fileId);
  storePwaIconUrls_(fileId);
  Logger.log('נרשם PWA_ICON_FILE_ID: ' + fileId);
  Logger.log('אייקון מסך הבית: ' + getDriveIconLh3Url_(fileId, 192));
  Logger.log('פתח בדפדפן – אמורה להופיע תמונת הלוגו');
}

