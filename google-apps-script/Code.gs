/** JSON ללוגו – iconUrl + base64 מחולק (נטען ב-JS, לא ב-src של התבנית) */
function getBrandLogoJson_() {
  var iconUrl = getBrandLogoIconUrl_();
  var pwaIconUrl = getPublicPwaIconUrl_(192);
  var payload;
  if (hasCustomLogoUrl_()) {
    payload = { type: 'dataUri', src: resolveLogoDataUri_(180), iconUrl: iconUrl, pwaIconUrl: pwaIconUrl };
  } else {
    var b64 = getIconPngBase64_(180);
    var chunk = 1200;
    var parts = [];
    for (var i = 0; i < b64.length; i += chunk) {
      parts.push(b64.substring(i, Math.min(i + chunk, b64.length)));
    }
    payload = { type: 'base64', parts: parts, iconUrl: iconUrl, pwaIconUrl: pwaIconUrl };
  }
  return JSON.stringify(payload).replace(/</g, '\\u003c');
}

/** כתובת לאייקון – LOGO_URL מותאם או endpoint מוטמע */
function getIconUrl_(size) {
  return getIconServeUrl_(size || 192);
}

function serveIconPng_(size) {
  if (hasCustomLogoUrl_()) {
    var blob = fetchLogoBlob_();
    if (blob) return blob.setName('icon-' + size + '.png');
  }
  return Utilities.newBlob(
    Utilities.base64Decode(getIconPngBase64_(size)),
    'image/png',
    'icon-' + size + '.png'
  );
}

function getWebAppUrl_() {
  try {
    return ScriptApp.getService().getUrl();
  } catch (e) {
    return '';
  }
}

/** נתיב scope ל-PWA – תיקיית האפליקציה (מעל /exec) */
function getPwaScopeUrl_(startUrl) {
  var u = String(startUrl || '').split('?')[0];
  if (!u) return '/';
  var last = u.lastIndexOf('/');
  if (last <= 0) return u + '/';
  return u.substring(0, last + 1);
}

function getAppConfigJson_() {
  var url = getWebAppUrlForClients_() || getWebAppUrl_();
  var startUrl = url ? url.split('?')[0] : '';
  return JSON.stringify({
    webAppUrl: url,
    startUrl: startUrl,
    scope: getPwaScopeUrl_(startUrl),
    manifestUrl: url + '?action=manifest',
    swUrl: url + '?action=sw',
    pwaIconReady: isPwaIconOnDriveReady_(),
  }).replace(/</g, '\\u003c');
}

/** אייקון PWA ב-Drive (לא script.google.com) – חובה להתקנה אמיתית ב-Chrome */
function isPwaIconOnDriveReady_() {
  var fileId = getPwaIconDriveFileId_();
  if (!fileId) return false;
  var icon192 = getPublicPwaIconUrl_(192);
  return icon192.indexOf('googleusercontent.com') >= 0 || icon192.indexOf('drive.google.com') >= 0;
}

/** אייקונים ל-manifest – כתובת Drive ציבורית (Android Chrome) */
function getManifestIcons_() {
  var sizes = [180, 192, 512];
  var icons = [];
  sizes.forEach(function (sz) {
    var src = getPublicPwaIconUrl_(sz);
    icons.push({
      src: src,
      sizes: sz + 'x' + sz,
      type: 'image/png',
      purpose: 'any',
    });
    icons.push({
      src: src,
      sizes: sz + 'x' + sz,
      type: 'image/png',
      purpose: 'maskable',
    });
  });
  return icons;
}

function getManifestJson_() {
  var url = getWebAppUrlForClients_() || getWebAppUrl_();
  var startUrl = url.split('?')[0];
  var scopeUrl = getPwaScopeUrl_(startUrl);
  return {
    id: startUrl,
    name: 'אנשי קשר - ישיבת אלון מורה',
    short_name: 'אנשי קשר',
    description: 'אנשי קשר לישיבת אלון מורה',
    lang: 'he',
    dir: 'rtl',
    start_url: startUrl,
    scope: scopeUrl,
    display: 'standalone',
    display_override: ['standalone', 'minimal-ui'],
    orientation: 'portrait-primary',
    background_color: '#0f1d42',
    theme_color: '#0f1d42',
    prefer_related_applications: false,
    categories: ['utilities', 'productivity'],
    icons: getManifestIcons_(),
  };
}

function getIconSvg_(size) {
  var s = Number(size) || 192;
  return (
    '<svg xmlns="http://www.w3.org/2000/svg" width="' +
    s +
    '" height="' +
    s +
    '" viewBox="0 0 512 512">' +
    '<defs>' +
    '<linearGradient id="bg" x1="72" y1="56" x2="440" y2="456" gradientUnits="userSpaceOnUse">' +
    '<stop stop-color="#26A69A"/><stop offset="1" stop-color="#004D40"/>' +
    '</linearGradient>' +
    '</defs>' +
    '<rect width="512" height="512" rx="112" fill="url(#bg)"/>' +
    '<circle cx="228" cy="196" r="78" fill="#FFFFFF" fill-opacity="0.96"/>' +
    '<path d="M92 418c0-82 61-130 136-130s136 48 136 130" stroke="#FFFFFF" stroke-width="38" stroke-linecap="round" fill="none"/>' +
    '<rect x="312" y="268" width="116" height="176" rx="30" fill="#FFFFFF" fill-opacity="0.94"/>' +
    '<rect x="336" y="300" width="68" height="14" rx="7" fill="#004D40" fill-opacity="0.3"/>' +
    '<circle cx="370" cy="400" r="10" fill="#004D40" fill-opacity="0.25"/>' +
    '</svg>'
  );
}

function getServiceWorkerScript_() {
  var url = getWebAppUrlForClients_() || getWebAppUrl_();
  var shell = JSON.stringify([url, url + '?action=manifest']);
  return (
    "const CACHE='contacts-yelm-v13';\n" +
    'const SHELL=' +
    shell +
    ';\n' +
    "self.addEventListener('install',function(e){\n" +
    '  e.waitUntil(\n' +
    "    caches.open(CACHE).then(function(c){\n" +
    '      return Promise.allSettled(SHELL.map(function(u){return c.add(u);}));\n' +
    '    }).then(function(){return self.skipWaiting();})\n' +
    '  );\n' +
    '});\n' +
    "self.addEventListener('activate',function(e){\n" +
    '  e.waitUntil(\n' +
    "    caches.keys().then(function(keys){\n" +
    '      return Promise.all(keys.filter(function(k){return k!==CACHE;}).map(function(k){return caches.delete(k);}));\n' +
    '    }).then(function(){return self.clients.claim();})\n' +
    '  );\n' +
    '});\n' +
    "self.addEventListener('fetch',function(e){\n" +
    "  if(e.request.method!=='GET')return;\n" +
    "  var u=e.request.url;\n" +
    "  if(u.indexOf('action=icon')>=0||u.indexOf('action=manifest')>=0||u.indexOf('action=sw')>=0||u.indexOf('action=list')>=0)return;\n" +
    '  e.respondWith(\n' +
    "    caches.match(e.request).then(function(cached){\n" +
    '      if(cached)return cached;\n' +
    '      return fetch(e.request).then(function(res){\n' +
    '        if(!res||res.status!==200)return res;\n' +
    '        var copy=res.clone();\n' +
    "        caches.open(CACHE).then(function(c){c.put(e.request,copy);});\n" +
    '        return res;\n' +
    '      }).catch(function(){return caches.match(e.request);});\n' +
    '    })\n' +
    '  );\n' +
    '});\n'
  );
}

function doGet(e) {
  try {
    var action = e && e.parameter && e.parameter.action;
    if (action === 'list') {
      return jsonResponse_({ ok: true, contacts: getContacts_() });
    }
    if (action === 'logo') {
      return jsonResponse_(getBrandLogoBootstrapPublic());
    }
    if (action === 'manifest') {
      return ContentService.createTextOutput(JSON.stringify(getManifestJson_())).setMimeType(
        'application/manifest+json'
      );
    }
    if (action === 'icon') {
      var size = (e.parameter && e.parameter.size) || '192';
      var iconBlob = serveIconPng_(size);
      return ContentService.createBlobOutput(iconBlob)
        .setMimeType(iconBlob.getContentType() || 'image/png')
        .setName('icon-' + size + '.png');
    }
    if (action === 'sw') {
      return ContentService.createTextOutput(getServiceWorkerScript_()).setMimeType(
        'application/javascript'
      );
    }

    var evaluated = HtmlService.createTemplateFromFile('Index').evaluate();
    var html = injectBrandLogoIntoHtml_(evaluated.getContent());
    return applyWebAppFavicon_(
      HtmlService.createHtmlOutput(html)
        .setTitle('אנשי קשר - ישיבת אלון מורה')
        .addMetaTag('viewport', 'width=device-width, initial-scale=1')
        .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
        .setSandboxMode(HtmlService.SandboxMode.NATIVE)
    );
  } catch (err) {
    return jsonResponse_({ ok: false, error: String(err) });
  }
}

function doPost(e) {
  try {
    var body = e.postData && e.postData.contents ? JSON.parse(e.postData.contents) : {};
    if (body.action === 'verify') {
      return jsonResponse_(verifyPasswordPublic(body.password));
    }
    if (body.action === 'add') {
      return jsonResponse_(addContactPublic(body.token, body.contact));
    }
    if (body.action === 'import') {
      return jsonResponse_(importContactsPublic(body.token, body.contacts));
    }
    if (body.action === 'dedupe') {
      return jsonResponse_(dedupeSheetPublic(body.token));
    }
    return jsonResponse_({ ok: false, error: 'פעולה לא מוכרת' });
  } catch (err) {
    return jsonResponse_({ ok: false, error: String(err) });
  }
}

