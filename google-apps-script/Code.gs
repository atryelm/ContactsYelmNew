var LOGO_CACHE_TTL_SEC = 21600;
var LOGO_INLINE_MAX_BYTES = 95000;

/** LOGO_URL גולמי מ-Script Properties (לא כתובת /exec של האפליקציה) */
function getRawLogoUrl_() {
  var u = String(getProp_('LOGO_URL', DEFAULT_LOGO_URL) || '').trim();
  if (/script\.google\.com\/macros/i.test(u)) return '';
  return u;
}

function hasCustomLogoUrl_() {
  var u = getRawLogoUrl_();
  return u.length > 0 && /^https?:\/\//i.test(u);
}

/** מזהה קובץ Drive מכל פורמט קישור נפוץ */
function extractDriveFileId_(raw) {
  var u = String(raw || '').trim();
  if (!u) return '';
  var m = u.match(/drive\.google\.com\/file\/d\/([a-zA-Z0-9_-]+)/);
  if (m) return m[1];
  m = u.match(/[?&]id=([a-zA-Z0-9_-]+)/);
  if (m && /google\.com/i.test(u)) return m[1];
  if (/^[a-zA-Z0-9_-]{20,}$/.test(u)) return u;
  return '';
}

function getLogoCacheKey_(size) {
  var raw = getRawLogoUrl_() || 'embedded';
  var digest = Utilities.computeDigest(Utilities.DigestAlgorithm.MD5, raw + '_' + (size || 180));
  var hex = digest.map(function (b) {
    return ('0' + (b < 0 ? b + 256 : b).toString(16)).slice(-2);
  }).join('');
  return 'logo_v14_' + hex;
}

/** תמונה קטנה ל-HTML (כותרת) – תמיד thumbnail ~112px */
function fetchLogoBlobForInline_() {
  var raw = getRawLogoUrl_();
  if (!raw) return null;
  var fileId = extractDriveFileId_(raw);
  if (fileId) {
    var thumb = fetchDriveThumbnailBlob_(fileId, 112);
    if (thumb) return thumb;
    try {
      var b = DriveApp.getFileById(fileId).getBlob();
      if (b.getBytes().length <= LOGO_INLINE_MAX_BYTES) return b;
    } catch (e) {
      Logger.log('fetchLogoBlobForInline_ Drive: ' + e);
    }
    return fetchDriveThumbnailBlob_(fileId, 512);
  }
  if (/^https?:\/\//i.test(raw)) {
    try {
      var resp = UrlFetchApp.fetch(raw, { muteHttpExceptions: true, followRedirects: true });
      if (resp.getResponseCode() === 200) {
        var blob = resp.getBlob();
        if (blob.getBytes().length <= LOGO_INLINE_MAX_BYTES) return blob;
      }
    } catch (e) {
      Logger.log('fetchLogoBlobForInline_ UrlFetch: ' + e);
    }
  }
  return null;
}

function blobToDataUri_(blob) {
  var mime = blob.getContentType() || 'image/png';
  if (mime.indexOf('image/') !== 0) mime = 'image/png';
  return 'data:' + mime + ';base64,' + Utilities.base64Encode(blob.getBytes());
}

function fetchDriveThumbnailBlob_(fileId, maxPx) {
  try {
    var url = 'https://drive.google.com/thumbnail?id=' + fileId + '&sz=w' + (maxPx || 512);
    var resp = UrlFetchApp.fetch(url, { muteHttpExceptions: true, followRedirects: true });
    if (resp.getResponseCode() === 200 && resp.getBlob().getBytes().length > 100) {
      return resp.getBlob();
    }
  } catch (e) {
    Logger.log('fetchDriveThumbnailBlob_: ' + e);
  }
  return null;
}

/** מביא Blob ללוגו: Drive (getFileById) או URL חיצוני (UrlFetchApp) */
function fetchLogoBlob_() {
  var raw = getRawLogoUrl_();
  if (!raw) return null;

  var fileId = extractDriveFileId_(raw);
  if (fileId || /drive\.google\.com/i.test(raw)) {
    if (!fileId) return null;
    try {
      var driveBlob = DriveApp.getFileById(fileId).getBlob();
      if (driveBlob.getBytes().length <= LOGO_INLINE_MAX_BYTES) return driveBlob;
      var thumb = fetchDriveThumbnailBlob_(fileId, 512);
      if (thumb) return thumb;
      return driveBlob;
    } catch (e) {
      Logger.log('fetchLogoBlob_ Drive: ' + e);
      return fetchDriveThumbnailBlob_(fileId, 512);
    }
  }

  if (/^https?:\/\//i.test(raw)) {
    try {
      var resp = UrlFetchApp.fetch(raw, { muteHttpExceptions: true, followRedirects: true });
      if (resp.getResponseCode() === 200) {
        var blob = resp.getBlob();
        if (blob.getBytes().length > 100) return blob;
      }
    } catch (e) {
      Logger.log('fetchLogoBlob_ UrlFetch: ' + e);
    }
  }
  return null;
}

function getFallbackIconDataUri_(size) {
  return 'data:image/png;base64,' + getIconPngBase64_(size);
}

/**
 * מחזיר data URI ללוגו (מטמון 6 שעות). נכשל → ICON_B64 מוטמע.
 */
function resolveLogoDataUri_(size) {
  if (!hasCustomLogoUrl_()) {
    return getFallbackIconDataUri_(size);
  }

  var cache = CacheService.getScriptCache();
  var cacheKey = getLogoCacheKey_(size);
  var cached = cache.get(cacheKey);
  if (cached && /^data:image\//i.test(cached)) {
    return cached;
  }

  var blob = fetchLogoBlobForInline_();
  if (!blob) {
    Logger.log('resolveLogoDataUri_: fetch failed, using ICON_B64');
    return getFallbackIconDataUri_(size);
  }

  var uri = blobToDataUri_(blob);
  if (uri.length <= LOGO_INLINE_MAX_BYTES) {
    try {
      cache.put(cacheKey, uri, LOGO_CACHE_TTL_SEC);
    } catch (e) {
      Logger.log('resolveLogoDataUri_ cache: ' + e);
    }
  }
  return uri;
}

/**
 * כתובת Web App ללקוחות – תמיד /exec (לא /dev).
 * testLogoSetup מהעורך מחזיר /dev; משתמשים ציבוריים פותחים /exec – אחרת הלוגו נשבר.
