/**
 * הרץ פעם אחת מהעורך – מבקש הרשאות Drive + גישה חיצונית (חלון אישור).
 * אחרי אישור הרץ שוב testLogoSetup().
 */
function authorizeScript() {
  UrlFetchApp.fetch('https://www.google.com', { muteHttpExceptions: true });
  logDriveAuthStatus_();
  Logger.log('---');
  if (getPwaIconDriveFileId_()) {
    Logger.log('אייקון PWA כבר רשום: ' + getPublicPwaIconUrl_(192));
  } else {
    Logger.log('אין עדיין אייקון PWA ב-Drive – הרץ registerPwaIconDriveFile אחרי העלאה ידנית');
    Logger.log('(או הרץ createPwaIconAuthTest ואז setupPwaIconOnDrive לאישור createFile)');
  }
  try {
    createPwaIconAuthTest();
    setupPwaIconOnDrive();
  } catch (e) {
    Logger.log('יצירה אוטומטית ב-Drive: ' + e);
  }
  if (getPwaIconDriveFileId_()) {
    refreshPwaIconUrls();
  }
  testLogoSetup();
}

/** הרץ מעורך הסקריפט: בודק שהלוגו נטען (ICON_B64 + כתובת) */
function testLogoSetup() {
  var urlDev = getWebAppUrl_();
  var urlPublic = getWebAppUrlForClients_();
  var rawLogo = getProp_('LOGO_URL', '');
  Logger.log('=== בדיקת לוגו ===');
  Logger.log('Script ID: ' + ScriptApp.getScriptId());
  Logger.log('כתובת מהעורך (/dev): ' + (urlDev || '(אין)'));
  Logger.log('כתובת לשיתוף (/exec) – פתח בדפדפן: ' + (urlPublic || '(אין)'));
  Logger.log('LOGO_URL גולמי: ' + (rawLogo || '(ריק)'));
  Logger.log('LOGO_URL פעיל: ' + (hasCustomLogoUrl_() ? 'כן' : 'לא (ICON_B64)'));
  Logger.log('מזהה Drive: ' + (extractDriveFileId_(rawLogo) || '(לא)'));
  var brandSrc = getBrandLogoImgSrc_();
  Logger.log('לוגו בכותרת (img): ' + brandSrc.substring(0, 60) + '... (' + brandSrc.length + ' תווים)');
  Logger.log('מוטמע data URI: ' + (/^data:image\//i.test(brandSrc) ? 'כן' : 'לא'));
  Logger.log('bootstrap JSON: ' + getBrandLogoBootstrapJson_().substring(0, 50) + '...');
  var faviconUrl = getFaviconUrlForWebApp_();
  Logger.log('setFaviconUrl (מסך הבית אנדרואיד): ' + faviconUrl);
  Logger.log('manifest icons: ' + getPublicPwaIconUrl_(192));
  if (!faviconUrl) {
    Logger.log('⚠ אין כתובת favicon – הרץ setupPwaIconOnDrive');
  } else if (!/format=png/i.test(faviconUrl)) {
    Logger.log('⚠ כתובת favicon חייבת להכיל format=png: ' + faviconUrl);
  } else {
    Logger.log('✓ setFaviconUrl (חייב export=download&format=png)');
    Logger.log('הערה: <link rel=icon> ב-Index לא משפיע – רק setFaviconUrl ב-doGet');
  }
  Logger.log('iconUrl בדף: ' + (getBrandLogoIconUrl_() || '(אין)'));
  var iconHref = getIconHref_(180);
  Logger.log('אייקון favicon: ' + iconHref.substring(0, 70) + '...');
  var blob = serveIconPng_(180);
  Logger.log('גודל PNG ל-action=icon: ' + blob.getBytes().length + ' bytes');
  Logger.log('בדיקת תמונה: פתח בטאב – ' + iconHref);
  Logger.log('אם הלוגו שבור באתר – ודא שאתה ב-/exec ולא ב-/dev, ופרוס New version');
}
