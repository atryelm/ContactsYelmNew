/** מחליף את תג הלוגו ב-HTML – bootstrap + טעינה מיידית ב-JS */
function injectBrandLogoIntoHtml_(html) {
  html = html.replace(/\salt=["'][^"']*לוגו[^"']*["']/gi, ' alt=""');

  var bootScript =
    '<script type="application/json" id="brand-logo-bootstrap">' +
    getBrandLogoBootstrapJson_() +
    '</script>';
  if (/id=["']brand-logo-bootstrap["']/i.test(html)) {
    html = html.replace(
      /<script[^>]*id=["']brand-logo-bootstrap["'][^>]*>[\s\S]*?<\/script>/i,
      bootScript
    );
  } else {
    html = html.replace(/<\/head>/i, bootScript + '\n</head>');
  }

  var imgTag =
    '<img class="brand-logo" id="brand-logo" width="56" height="56" decoding="async" ' +
    'data-logo-v="17" alt="" onerror="if(window.__logoFallback)window.__logoFallback(this)" />' +
    BRAND_LOGO_INLINE_LOADER_;

  html = html.replace(
    /<script>\(function\(\)\{var b=document\.getElementById\("brand-logo-bootstrap"\)[\s\S]*?<\/script>/g,
    ''
  );

  if (/<img[\s\S]*?\bid=["']brand-logo["']/i.test(html)) {
    html = html.replace(/<img[\s\S]*?\bid=["']brand-logo["'][\s\S]*?\/?>/i, imgTag);
  } else if (/<div[^>]*\bid=["']brand-logo["']/i.test(html)) {
    var d = String.fromCharCode(100, 105, 118);
    var divLogoRe = new RegExp(
      '<' + d + '[^>]*\\bid=["\']brand-logo["\'][^>]*>[\\s\\S]*?</' + d + '>',
      'i'
    );
    html = html.replace(divLogoRe, imgTag);
  } else {
    html = html.replace(/(<div class="brand"[^>]*>)/i, '$1\n' + imgTag + '\n');
  }
  return html;
}

function include(filename) {
  if (!filename || String(filename) === 'undefined') {
    throw new Error(
      'לא להריץ את include ישירות מהעורך. ' +
        'הרץ testListContacts לבדיקת גיליון, או Deploy את האפליקציה. ' +
        'ודא שיש קובץ HTML בשם Index (העתק מ-Index-להדבקה-ב-AppsScript.html).'
    );
  }
  try {
    return HtmlService.createHtmlOutputFromFile(String(filename)).getContent();
  } catch (e) {
    throw new Error(
      'חסר קובץ HTML: "' +
        filename +
        '". צור ב-Apps Script: + → HTML → שם בדיוק "' +
        filename +
        '" (בלי .html). או השתמש ב-Index-להדבקה-ב-AppsScript.html (קובץ אחד).'
    );
  }
}

function includeScript(filename) {
  if (!filename) {
    throw new Error('includeScript נקרא בלי שם קובץ. ודא ש-Index.html מכיל includeScript(\'Client\') או השתמש בקובץ המאוחד.');
  }
  return include(filename)
    .replace(/<\/script/gi, '<\\/script')
    .replace(/<!--/g, '<\\!--');
}

